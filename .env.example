# ============================================
# CS2 Simu Project — 开发环境变量配置
# 使用方式: 复制此文件为 .env 后根据需要修改
# ============================================

# === 数据库配置 ===
DB_PASSWORD=nakama

# === Nakama 配置 ===
NAKAMA_SERVER_KEY=defaultkey
CONSOLE_USERNAME=admin
CONSOLE_PASSWORD=password

# === 前端配置 ===
FRONTEND_PORT=3000

# === 前端环境变量 (Vite 构建时使用) ===
# Option A (宿主机开发): localhost
# Option B (Docker 构建): nakama
# 默认值: localhost
VITE_NAKAMA_HOST=localhost
VITE_NAKAMA_PORT=7350
VITE_NAKAMA_SERVER_KEY=defaultkey
VITE_NAKAMA_USE_SSL=false
